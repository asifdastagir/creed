{% comment %}
  Product Carousel
  Mobile: 1.2 slides | Desktop: 6 slides
  Centered header + swipe-to-browse hint
{% endcomment %}

{%- liquid
  assign collection = collections[section.settings.collection]
  assign product_limit = section.settings.limit
-%}

<section
  id="productCarousel-{{ section.id }}"
  class="product-carousel component bg-white py-10 lg:py-16"
  style="margin-top: {{ section.settings.margin_top }}px; margin-bottom: {{ section.settings.margin_bottom }}px;"
>
  <div class="container">
    <div class="product-carousel__header text-center mb-8 lg:mb-12">
      {% if section.settings.eyebrow != blank %}
        <p class="product-carousel__eyebrow tracking-[0.15em] uppercase text-[11px] lg:text-[12px] text-[#9A9A9A] mb-2">
          {{ section.settings.eyebrow }}
        </p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="product-carousel__heading uppercase tracking-[0.04em] text-[28px] lg:text-[42px] font-semibold text-black leading-none mb-3">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.swipe_label != blank %}
        <p class="product-carousel__swipe tracking-[0.18em] uppercase text-[11px] lg:text-[12px] text-[#9A9A9A]">
          {{ section.settings.swipe_label }}
        </p>
      {% endif %}
    </div>

    <div class="product-carousel__slider">
      <swiper-carousel>
        <div class="swiper-container product-carousel-swiper">
          <div class="swiper-wrapper">
            {%- if collection != blank and collection.products_count > 0 -%}
              {%- assign carousel_products = collection.products | sort: 'created_at' | reverse -%}
              {%- for product in carousel_products limit: product_limit -%}
                {%- liquid
                  assign related_colors = product.metafields.custom.related_colors.value
                  if related_colors != blank
                    assign related_colors = related_colors | sort: 'handle'
                  endif

                  assign default_variant = product.selected_or_first_available_variant | default: product.variants.first
                  assign default_image = default_variant.featured_media | default: product.featured_media
                -%}
                <div class="swiper-slide product-carousel__slide">
                  <div class="product-carousel__card group p-2" data-product-card>
                    <a
                      href="{{ product.url }}"
                      class="product-carousel__link block"
                      data-product-link
                      {% if default_variant %}
                        data-product-url="{{ product.url }}"
                      {% endif %}
                    >
                      <div class="product-carousel__media relative overflow-hidden bg-[#FFFFFF] aspect-[3/4] mb-3 lg:mb-4 border border-black">
                        {% if default_image != blank %}
                          <img
                            src="{{ default_image | image_url: width: 800 }}"
                            alt="{{ default_image.alt | default: product.title | escape }}"
                            class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-[1.03]"
                            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                            width="{{ default_image.width }}"
                            height="{{ default_image.height }}"
                            data-product-image
                          >
                        {% else %}
                          {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover' }}
                        {% endif %}
                      </div>

                      <div class="product-carousel__info">
                        {%- assign category_label = product.type -%}
                        {%- if category_label == blank and product.tags.size > 0 -%}
                          {%- assign category_label = product.tags.first -%}
                        {%- endif -%}

                        {% if category_label != blank %}
                          <p class="product-carousel__category tracking-[0.14em] uppercase text-[10px] lg:text-[11px] text-[#9A9A9A] mb-1">
                            {{ category_label }}
                          </p>
                        {% endif %}

                        <h3 class="product-carousel__title text-[15px] lg:text-[16px] text-black leading-snug mb-1" data-product-title>
                          {{ product.title | escape }}
                        </h3>

                        <p class="product-carousel__price text-[14px] lg:text-[15px] text-[#8A8A8A] mb-2" data-product-price>
                          {{ default_variant.price | money }}
                          {% if default_variant.compare_at_price > default_variant.price %}
                            <span class="line-through ml-1 opacity-70">{{ default_variant.compare_at_price | money }}</span>
                          {% endif %}
                        </p>
                      </div>
                    </a>

                    {% if related_colors != blank %}
                      <div class="product-carousel__swatches swiper-no-swiping flex items-center gap-3 mt-auto pt-1" aria-label="Available colors" data-product-swatches>
                        {% for sibling in related_colors limit: 8 %}
                          {% unless sibling == blank %}
                            {%- liquid
                              assign is_active = false
                              if sibling.id == product.id
                                assign is_active = true
                              endif
                            -%}
                            {% render 'product-carousel-color-swatch',
                              sibling: sibling,
                              current_product: product,
                              is_active: is_active
                            %}
                          {% endunless %}
                        {% endfor %}
                      </div>
                    {% endif %}
                  </div>
                </div>
              {%- endfor -%}
            {%- else -%}
              {%- for i in (1..6) -%}
                <div class="swiper-slide product-carousel__slide">
                  <div class="product-carousel__card p-2">
                    <div class="product-carousel__media bg-[#EFEFEF] aspect-[3/4] mb-3 lg:mb-4 border border-black flex items-center justify-center">
                      {{ 'product-1' | placeholder_svg_tag: 'w-2/3 h-2/3 opacity-40' }}
                    </div>
                    <p class="product-carousel__category tracking-[0.14em] uppercase text-[10px] text-[#9A9A9A] mb-1">Category</p>
                    <h3 class="product-carousel__title text-[15px] text-black mb-1">Product title</h3>
                    <p class="product-carousel__price text-[14px] text-[#8A8A8A] mb-2">$00.00</p>
                    <div class="product-carousel__swatches flex items-center gap-1.5">
                      <span class="product-carousel__swatch bg-black"></span>
                      <span class="product-carousel__swatch bg-white"></span>
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            {%- endif -%}
          </div>
        </div>

        <script type="application/json">
          {
            "slidesPerView": 1.2,
            "spaceBetween": 12,
            "watchOverflow": true,
            "grabCursor": true,
            "preventClicks": false,
            "preventClicksPropagation": false,
            "noSwiping": true,
            "noSwipingClass": "swiper-no-swiping",
            "breakpoints": {
              "768": {
                "slidesPerView": 3,
                "spaceBetween": 16
              },
              "1024": {
                "slidesPerView": 4,
                "spaceBetween": 18
              },
              "1280": {
                "slidesPerView": 5.3,
                "spaceBetween": 20
              }
            }
          }
        </script>
      </swiper-carousel>
    </div>
  </div>
</section>

<style>
  #productCarousel-{{ section.id }} .product-carousel-swiper {
    overflow: hidden;
  }

  #productCarousel-{{ section.id }} .swiper-wrapper {
    align-items: stretch;
  }

  #productCarousel-{{ section.id }} .product-carousel__slide {
    height: auto;
    display: flex;
  }

  #productCarousel-{{ section.id }} .product-carousel__card {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
  }

  #productCarousel-{{ section.id }} .product-carousel__link {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    color: inherit;
    text-decoration: none;
  }

  #productCarousel-{{ section.id }} .product-carousel__info {
    display: flex;
    flex-direction: column;
  }

  #productCarousel-{{ section.id }} .product-carousel__swatches {
    margin-top: auto;
    position: relative;
    z-index: 6;
    pointer-events: auto;
    gap: 12px;
  }

  #productCarousel-{{ section.id }} .product-carousel__media {
    border-color: #000;
    box-sizing: border-box;
  }

  #productCarousel-{{ section.id }} .product-carousel__swatch {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 12px;
    height: 12px;
    border-radius: 9999px;
    border: 1px solid #000;
    padding: 0;
    margin: 0;
    cursor: pointer;
    flex-shrink: 0;
    box-sizing: border-box;
    appearance: none;
    -webkit-appearance: none;
    background-color: transparent;
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    pointer-events: auto;
    z-index: 5;
  }

  #productCarousel-{{ section.id }} .product-carousel__swatch::before {
    content: '';
    position: absolute;
    inset: -8px;
  }

  #productCarousel-{{ section.id }} .product-carousel__swatch.is-active {
    box-shadow: 0 0 0 2px #fff, 0 0 0 3px #000;
    transform: scale(1.08);
  }

  #productCarousel-{{ section.id }} .product-carousel__swatch.is-light {
    border-color: #cdd8e1;
  }

  #productCarousel-{{ section.id }} .product-carousel__swatch.is-light.is-active {
    border-color: #000;
  }

  #productCarousel-{{ section.id }} .product-carousel__media img {
    transition: opacity 0.2s ease, transform 0.5s ease;
  }

  #productCarousel-{{ section.id }} .product-carousel__media img.is-switching {
    opacity: 0.45;
  }
</style>

<script>
  (function () {
    function applySwatch(swatch) {
      if (!swatch) return;

      var card = swatch.closest('[data-product-card]');
      if (!card) return;

      var image = card.querySelector('[data-product-image]');
      var link = card.querySelector('[data-product-link]');
      var price = card.querySelector('[data-product-price]');
      var title = card.querySelector('[data-product-title]');
      var imageUrl = swatch.getAttribute('data-image');
      var imageAlt = swatch.getAttribute('data-image-alt');
      var productUrl = swatch.getAttribute('data-url');
      var priceText = swatch.getAttribute('data-price');
      var comparePrice = swatch.getAttribute('data-compare-price');
      var titleText = swatch.getAttribute('data-title');

      card.querySelectorAll('[data-carousel-swatch]').forEach(function (item) {
        item.classList.toggle('is-active', item === swatch);
      });

      if (image && imageUrl && image.getAttribute('src') !== imageUrl) {
        image.classList.add('is-switching');
        var preload = new Image();
        preload.onload = function () {
          image.src = imageUrl;
          if (imageAlt) image.alt = imageAlt;
          image.classList.remove('is-switching');
        };
        preload.onerror = function () {
          image.src = imageUrl;
          image.classList.remove('is-switching');
        };
        preload.src = imageUrl;
      }

      if (link && productUrl) {
        link.setAttribute('href', productUrl);
      }

      if (title && titleText) {
        title.textContent = titleText;
      }

      if (price && priceText) {
        if (comparePrice) {
          price.innerHTML = priceText + ' <span class="line-through ml-1 opacity-70">' + comparePrice + '</span>';
        } else {
          price.textContent = priceText;
        }
      }
    }

    var lastSwatchAt = 0;

    function onSwatchInteract(event) {
      var swatch = event.target.closest('[data-carousel-swatch]');
      if (!swatch) return;

      var root = document.getElementById('productCarousel-{{ section.id }}');
      if (!root || !root.contains(swatch)) return;

      var now = Date.now();
      if (now - lastSwatchAt < 300) {
        event.preventDefault();
        event.stopPropagation();
        return;
      }
      lastSwatchAt = now;

      event.preventDefault();
      event.stopPropagation();
      applySwatch(swatch);
    }

    document.addEventListener('click', onSwatchInteract, true);
  })();
</script>

{% schema %}
{
  "name": "Product Carousel",
  "tag": "section",
  "class": "product-carousel-section",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "NEW ARRIVALS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SHOP NOCTURN"
    },
    {
      "type": "text",
      "id": "swipe_label",
      "label": "Swipe label",
      "default": "SWIPE TO BROWSE →"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 4,
      "max": 24,
      "step": 1,
      "label": "Products to show",
      "default": 12
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Margin top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Margin bottom",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Product Carousel",
      "category": "Products"
    }
  ]
}
{% endschema %}
