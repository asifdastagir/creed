{% comment %}
  Hero Carousel Section
  Full-screen image carousel with responsive picture tag.
  Shared left-bottom text + CTA managed in section settings (not per slide).
{% endcomment %}

<section
  id="heroCarousel-{{ section.id }}"
  class="hero-carousel relative h-screen clip-container bg-black text-white overflow-hidden"
>
  <div class="swiper hero-carousel-swiper h-full" data-hero-carousel>
    <div class="swiper-wrapper h-full">
      {% for block in section.blocks %}
        <div class="swiper-slide h-full relative" {{ block.shopify_attributes }}>
          <div class="absolute inset-0 after:absolute after:inset-0 after:bg-black/30 after:z-[1]">
            {% if block.settings.image_desktop != blank or block.settings.image_mobile != blank %}
              <picture class="absolute inset-0 block w-full h-full">
                {% if block.settings.image_mobile != blank %}
                  <source
                    media="(max-width: 767px)"
                    srcset="{{ block.settings.image_mobile | image_url: width: 1000 }}"
                  >
                {% endif %}
                {% if block.settings.image_desktop != blank %}
                  <img
                    src="{{ block.settings.image_desktop | image_url: width: 1920 }}"
                    alt="{{ block.settings.image_desktop.alt | default: section.settings.heading_line_1 | escape }}"
                    class="w-full h-full object-cover"
                    {% if forloop.first %}
                      loading="eager"
                      fetchpriority="high"
                    {% else %}
                      loading="lazy"
                    {% endif %}
                    width="{{ block.settings.image_desktop.width }}"
                    height="{{ block.settings.image_desktop.height }}"
                  >
                {% elsif block.settings.image_mobile != blank %}
                  <img
                    src="{{ block.settings.image_mobile | image_url: width: 1000 }}"
                    alt="{{ block.settings.image_mobile.alt | default: section.settings.heading_line_1 | escape }}"
                    class="w-full h-full object-cover"
                    {% if forloop.first %}
                      loading="eager"
                      fetchpriority="high"
                    {% else %}
                      loading="lazy"
                    {% endif %}
                    width="{{ block.settings.image_mobile.width }}"
                    height="{{ block.settings.image_mobile.height }}"
                  >
                {% endif %}
              </picture>
            {% else %}
              <div class="absolute inset-0 bg-neutral-800"></div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="absolute inset-0 z-10 px-gutter grid-layout h-full pointer-events-none">
    <div class="row-start-1 col-start-1 col-end-8 sm:col-start-1 sm:col-end-5 md:col-start-1 md:col-end-6 flex items-end mb-[100px] lg:mb-[40px] pb-20 lg:pb-8">
      <div class="flex flex-col gap-0 pointer-events-auto">
        {% if section.settings.heading_line_1 != blank or section.settings.heading_line_2 != blank %}
          <h4 class="text-[200] text-[20px] lg:text-[26px] tracking-[12px]">
            {% if section.settings.heading_line_1 != blank %}
              <span class="flex">{{ section.settings.heading_line_1 }}</span>
            {% endif %}
          </h4>
          <h2 class="lead-text">
            {% if section.settings.heading_line_2 != blank %}
              <span class="flex">{{ section.settings.heading_line_2 }}</span>
            {% endif %}
          </h2>
        {% endif %}

        {% if section.settings.volume_label != blank %}
          <h6 class="w-full tracking-[0.15em] mb-2 lg:mb-4 text-[18px] lg:text-[22px]">
            {{ section.settings.volume_label }}
          </h6>
        {% endif %}

        {% if section.settings.description != blank %}
          <h6 class="w-full tracking-[0.15em] text-[18px] lg:text-[22px]">{{ section.settings.description }}</h6>
        {% endif %}

        {% if section.settings.button_label != blank %}
          <a
            href="{{ section.settings.button_url | default: '#' }}"
            class="flex items-center text-pre medium group/play w-fit px-[20px] py-[12px] bg-white text-black rounded-[3px] mt-2"
          >
            <span>{{ section.settings.button_label }}</span>
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% if section.blocks.size > 1 %}
  <style>
    #heroCarousel-{{ section.id }} .swiper-pagination-bullet {
      width: 8px;
      height: 8px;
      border-radius: 9999px;
      background: rgba(255, 255, 255, 0.4);
      opacity: 1;
      cursor: pointer;
      transition: background 0.3s ease, width 0.3s ease;
    }
    #heroCarousel-{{ section.id }} .swiper-pagination-bullet-active {
      background: #fff;
      width: 24px;
    }
  </style>

  <script>
    (function () {
      function initHeroCarousel() {
        var root = document.getElementById('heroCarousel-{{ section.id }}');
        if (!root || typeof Swiper === 'undefined') return;
        var el = root.querySelector('[data-hero-carousel]');
        if (!el || el.swiper) return;

        new Swiper(el, {
          slidesPerView: 1,
          loop: {{ section.settings.enable_loop }},
          speed: {{ section.settings.transition_speed }},
          effect: 'fade',
          fadeEffect: { crossFade: true },
          autoplay: {% if section.settings.enable_autoplay %}{
            delay: {{ section.settings.autoplay_delay }},
            disableOnInteraction: false
          }{% else %}false{% endif %},
          pagination: {
            el: root.querySelector('.hero-carousel-pagination'),
            clickable: true
          }
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initHeroCarousel);
      } else {
        initHeroCarousel();
      }
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Hero Carousel",
  "tag": "section",
  "class": "hero-carousel-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading line 1",
      "default": "Active for"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading line 2",
      "default": "the Faithful"
    },
    {
      "type": "text",
      "id": "volume_label",
      "label": "Volume label",
      "default": "VOL. 02"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Technical training apparel which blends performance with faith conscious design"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Carousel Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "min": 2000,
      "max": 9000,
      "step": 500,
      "unit": "ms",
      "label": "Autoplay delay",
      "default": 5000
    },
    {
      "type": "range",
      "id": "transition_speed",
      "min": 300,
      "max": 1500,
      "step": 100,
      "unit": "ms",
      "label": "Transition speed",
      "default": 800
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "label": "Enable loop",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Images"
        },
        {
          "type": "image_picker",
          "id": "image_desktop",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile image",
          "info": "Shown below 768px via picture tag"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Carousel",
      "category": "Hero",
      "settings": {
        "heading_line_1": "Active for",
        "heading_line_2": "the Faithful",
        "volume_label": "VOL. 02",
        "description": "Technical training apparel which blends performance with faith conscious design",
        "button_label": "Shop now"
      },
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
