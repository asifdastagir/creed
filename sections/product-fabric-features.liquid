{% comment %}
  Product Fabric Features
  Data from metafields:
  - custom.features (list of metaobjects)
  - custom.video (YouTube URL)
  - custom.video_and_textarea (About Fabric Title — rich text)
  - custom.about_fabric_desciption (About Fabric description)
{% endcomment %}

{%- liquid
  assign features = product.metafields.custom.features.value
  assign video_url = product.metafields.custom.video.value | default: product.metafields.custom.video
  assign about_title_metafield = product.metafields.custom.video_and_textarea
  assign about_desc_metafield = product.metafields.custom.about_fabric_desciption

  assign fabric_heading_html = blank
  assign fabric_heading_text = section.settings.heading
  assign fabric_body_text = blank

  if about_title_metafield != blank
    assign fabric_heading_html = about_title_metafield | metafield_tag
  endif

  if about_desc_metafield != blank and about_desc_metafield.value != blank
    assign fabric_body_text = about_desc_metafield.value
  elsif about_desc_metafield != blank
    assign fabric_body_text = about_desc_metafield
  endif

  assign video_id = blank
  if video_url != blank
    if video_url contains 'youtu.be/'
      assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first | split: '&' | first
    elsif video_url contains 'youtube.com/watch'
      assign video_id = video_url | split: 'v=' | last | split: '&' | first
    elsif video_url contains 'youtube.com/embed/'
      assign video_id = video_url | split: 'embed/' | last | split: '?' | first | split: '&' | first
    elsif video_url contains 'youtube.com/shorts/'
      assign video_id = video_url | split: 'shorts/' | last | split: '?' | first | split: '&' | first
    endif
  endif

  assign has_features = false
  if features != blank and features.size > 0
    assign has_features = true
  endif

  assign has_right_content = false
  if fabric_heading_text != blank or fabric_heading_html != blank or fabric_body_text != blank or video_id != blank
    assign has_right_content = true
  endif

  assign show_section = false
  if has_features or has_right_content
    assign show_section = true
  endif
-%}

{% if show_section %}
<section
  id="productFabricFeatures-{{ section.id }}"
  class="product-fabric-features{% unless has_right_content %} product-fabric-features--cards-only{% endunless %}"
  style="
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    background-color: {{ section.settings.background_color }};
  "
>
  <div class="product-fabric-features__inner">
    <div class="product-fabric-features__grid">
      {% if has_features %}
        <div class="product-fabric-features__cards">
          {% for feature in features %}
            {%- liquid
              assign feature_title = feature.feature_title.value | default: feature.feature_title
              assign feature_description = feature.feature_description.value | default: feature.feature_description
              assign feature_icon = feature.feature_icon.value | default: feature.feature_icon
            -%}
            <article class="product-fabric-features__card">
              {% if feature_icon != blank %}
                <div class="product-fabric-features__icon">
                  <img
                    src="{{ feature_icon | image_url: width: 80 }}"
                    alt="{{ feature_title | escape }}"
                    width="80"
                    height="80"
                    loading="lazy"
                  >
                </div>
              {% endif %}

              {% if feature_title != blank %}
                <h3 class="product-fabric-features__card-title">{{ feature_title }}</h3>
              {% endif %}

              {% if feature_description != blank %}
                <p class="product-fabric-features__card-text">{{ feature_description | newline_to_br }}</p>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      {% endif %}

      {% if has_right_content %}
        <div class="product-fabric-features__content">
          <div class="product-fabric-features__intro">
            {% if fabric_heading_text != blank %}
              <h2 class="product-fabric-features__heading">{{ fabric_heading_text }}</h2>
            {% elsif fabric_heading_html != blank %}
              <div class="product-fabric-features__heading rte">
                {{ fabric_heading_html }}
              </div>
            {% endif %}

            {% if fabric_body_text != blank %}
              <div class="product-fabric-features__body">
                <p>
                  <svg style="display: inline-block; vertical-align: bottom;" width="48" height="30" viewBox="0 0 48 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M24.3594 0.373047L47.7568 25.2295C45.0244 22.6153 41.3241 22.3536 37.5381 22.7656C33.7289 23.1803 29.5534 24.6259 25.2207 26.0703C20.9168 27.5051 16.4673 28.934 12.207 29.2363C7.92587 29.5401 3.79996 28.7094 0.174805 25.6025L0 25.2207L0.138672 24.875L23.6396 0.375L23.998 0L24.3594 0.373047Z" fill="#D11C27"/>
                  </svg>
                  {{ fabric_body_text | escape | newline_to_br }}
                </p>
              </div>
            {% endif %}
          </div>

          {% if video_id != blank %}
            <div class="product-fabric-features__media">
              <div class="product-fabric-features__video">
                <iframe
                  src="https://www.youtube.com/embed/{{ video_id }}"
                  title="{{ fabric_heading_text | default: product.title | escape }}"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                ></iframe>
              </div>
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #productFabricFeatures-{{ section.id }} .product-fabric-features__inner {
    max-width: 1380px;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    padding: 36px 20px;
    box-sizing: border-box;
  }

  /* Mobile: heading + text first (centered), then feature cards, then video/buttons */
  #productFabricFeatures-{{ section.id }} .product-fabric-features__grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: stretch;
  }

  #productFabricFeatures-{{ section.id }} .product-fabric-features__content {
    display: contents;
  }

  #productFabricFeatures-{{ section.id }} .product-fabric-features__intro {
    order: 1;
    text-align: center;
  }

  #productFabricFeatures-{{ section.id }} .product-fabric-features__cards {
    order: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }

  /* Cards only: single column on mobile, 2-column centered on larger screens */
  #productFabricFeatures-{{ section.id }}.product-fabric-features--cards-only .product-fabric-features__cards {
    grid-template-columns: 1fr;
    gap: 14px;
    width: 100%;
    max-width: 920px;
    margin-left: auto;
    margin-right: auto;
  }

  #productFabricFeatures-{{ section.id }}.product-fabric-features--cards-only .product-fabric-features__grid {
    align-items: center;
  }

  @media (min-width: 768px) {
    #productFabricFeatures-{{ section.id }}.product-fabric-features--cards-only .product-fabric-features__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  #productFabricFeatures-{{ section.id }} .product-fabric-features__media {
    order: 3;
  }

  #productFabricFeatures-{{ section.id }} .product-fabric-features__card {
    background: #fff;
    border-radius: 4px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    padding: 24px 22px;
    text-align: left;
  }

  #productFabricFeatures-{{ section.id }} .product-fabric-features__icon {
    margin-bottom: 12px;
  }

  #productFabricFeatures-{{ section.id }} .product-fabric-features__icon img {
    width: 80px;
    height: 80px;
    object-fit: contain;
    display: block;
  }

  #productFabricFeatures-{{ section.id }} .product-fabric-features__card-title {
    margin: 0 0 8px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #111;
  }

  #productFabricFeatures-{{ section.id }} .product-fabric-features__card-text {
    margin: 0;
    font-size: 13px;
    line-height: 1.55;
    color: #777;
  }

  #productFabricFeatures-{{ section.id }} .product-fabric-features__heading {
    margin: 0 0 14px;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #111;
    line-height: 1.2;
  }

  #productFabricFeatures-{{ section.id }} .product-fabric-features__heading.rte :is(p, h1, h2, h3, h4, h5, h6) {
    margin: 0;
    font-size: inherit;
    font-weight: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    color: inherit;
    line-height: inherit;
  }

  #productFabricFeatures-{{ section.id }} .product-fabric-features__body {
    margin: 0;
    font-size: 14px;
    line-height: 1.65;
    color: #555;
  }

  #productFabricFeatures-{{ section.id }} .product-fabric-features__video {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #000;
    margin-bottom: 16px;
    overflow: hidden;
  }

  #productFabricFeatures-{{ section.id }} .product-fabric-features__video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  #productFabricFeatures-{{ section.id }} .product-fabric-features__actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  #productFabricFeatures-{{ section.id }} .product-fabric-features__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 44px;
    padding: 10px 22px;
    background: #2a2a2a;
    color: #fff;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 12px;
    font-weight: 600;
    border: none;
    transition: background 0.25s ease;
  }

  #productFabricFeatures-{{ section.id }} .product-fabric-features__btn:hover {
    background: #000;
    color: #fff;
  }

  /* Desktop: cards left, content right */
  @media (min-width: 992px) {
    #productFabricFeatures-{{ section.id }} .product-fabric-features__inner {
      padding-top: 60px;
      padding-bottom: 60px;
      padding-left: 20px;
      padding-right: 20px;
    }

    #productFabricFeatures-{{ section.id }} .product-fabric-features__grid {
      display: grid;
      grid-template-columns: minmax(260px, 0.9fr) minmax(0, 1.4fr);
      gap: 40px;
      align-items: start;
    }

    #productFabricFeatures-{{ section.id }}.product-fabric-features--cards-only .product-fabric-features__grid {
      grid-template-columns: 1fr;
      justify-items: center;
    }

    #productFabricFeatures-{{ section.id }}.product-fabric-features--cards-only .product-fabric-features__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px;
      width: 100%;
      max-width: 980px;
    }

    #productFabricFeatures-{{ section.id }} .product-fabric-features__content {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    #productFabricFeatures-{{ section.id }} .product-fabric-features__intro,
    #productFabricFeatures-{{ section.id }} .product-fabric-features__cards,
    #productFabricFeatures-{{ section.id }} .product-fabric-features__media {
      order: unset;
    }

    #productFabricFeatures-{{ section.id }} .product-fabric-features__intro {
      text-align: left;
    }

    #productFabricFeatures-{{ section.id }} .product-fabric-features__heading {
      font-size: 36px;
      margin-bottom: 16px;
    }

    #productFabricFeatures-{{ section.id }} .product-fabric-features__body {
      font-size: 15px;
    }

    #productFabricFeatures-{{ section.id }} .product-fabric-features__actions {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 12px;
    }

    #productFabricFeatures-{{ section.id }} .product-fabric-features__btn {
      width: auto;
    }

    #productFabricFeatures-{{ section.id }} .product-fabric-features__card {
      padding: 20px 22px;
    }
  }
</style>
{% endif %}

{% schema %}
{
  "name": "Fabric Features",
  "tag": "section",
  "class": "product-fabric-features-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Uses metafields: custom.features, custom.video, custom.video_and_textarea (About Fabric Title), custom.about_fabric_desciption (description)."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading override",
      "info": "Optional. If set, replaces the About Fabric Title metafield."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#F3F3F3"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Button 1 label",
      "default": "SHOP TETRA-LITE"
    },
    {
      "type": "url",
      "id": "button_1_url",
      "label": "Button 1 link"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Button 2 label",
      "default": "EXPLORE ALL FABRICS"
    },
    {
      "type": "url",
      "id": "button_2_url",
      "label": "Button 2 link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Margin top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Margin bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Fabric Features"
    }
  ]
}
{% endschema %}
