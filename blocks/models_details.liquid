{% assign model = product.metafields.custom.models_details.value %}

{% if model %}
  <div style="padding: 16px 0;">
    <div style="display: flex; align-items: center; gap: 24px;">

      {% if model.model_image.value %}
        <img
          src="{{ model.model_image.value | image_url: width: 120 }}"
          alt="Model"
          style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; flex-shrink: 0;"
        >
      {% endif %}

      <div>
        <p style="font-weight: 700; font-style: italic; margin: 0 0 12px; font-size: 15px; text-transform: uppercase; letter-spacing: 0.05em;">
          {{ model.display_name }}
        </p>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px 40px; font-size: 13px; letter-spacing: 0.03em;">
          <span><strong>HEIGHT:</strong> {{ model.model_height.value }}</span>
          <span><strong>CHEST:</strong> {{ model.model_chest.value }}</span>
          <span><strong>WAIST:</strong> {{ model.model_waist.value }}</span>
          <span><strong>WEARS:</strong> {{ model.wears.value }}</span>
        </div>
      </div>

    </div>
  </div>
{% else %}
  <p style="color: #999; font-size: 13px;">No model details linked to this product.</p>
{% endif %}

{% schema %}
{
  "name": "Model Details"
}
{% endschema %}

