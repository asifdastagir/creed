{% doc %}
  @prompt
    Create a "Model Details" Liquid block for a Shopify product page collapsible tab. It must:
    
    - Read a metaobject reference from the product metafield: namespace "custom", key "models_details" (type: metaobject_reference, metaobject type: model_details)
    - From the metaobject, access these fields: model_image (file_reference), model_height (text), model_chest (text), model_waist (text), wears (text)
    - Display layout:
      - Horizontal rule at top
      - Row with: circular cropped model photo on the left (from model_image file reference), and on the right: model name in bold italic (use the metaobject's display name), then a 2-column stat grid: "HEIGHT: [value]" and "CHEST: [value]" on row 1, "WAIST: [value]" and "WEARS: [value]" on row 2
      - All stat labels uppercase, clean sans-serif, minimal spacing
      - Horizontal rule at bottom
    - Clean minimal CSS, white background
    - Liquid: access metaobject via product.metafields.custom.models_details.value, then fields via metaobject.model_image.value, metaobject.model_height.value, metaobject.model_chest.value, metaobject.model_waist.value, metaobject.wears.value
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign metaobject = product.metafields.custom.models_details.value %}

{% style %}
  .ai-model-details-{{ ai_gen_id }} {
    display: block;
    background-color: #ffffff;
    width: 100%;
  }

  .ai-model-details-hr-{{ ai_gen_id }} {
    border: none;
    border-top: 1px solid #e0e0e0;
    margin: 0;
  }

  .ai-model-details-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 24px 0;
  }

  .ai-model-details-image-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-model-details-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-model-details-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-model-details-name-{{ ai_gen_id }} {
    font-weight: 700;
    font-style: italic;
    font-size: 16px;
    margin: 0 0 12px 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  }

  .ai-model-details-stats-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 16px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 13px;
  }

  .ai-model-details-stat-{{ ai_gen_id }} {
    display: flex;
    gap: 6px;
  }

  .ai-model-details-stat-label-{{ ai_gen_id }} {
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .ai-model-details-stat-value-{{ ai_gen_id }} {
    font-weight: 400;
  }

  .ai-model-details-empty-{{ ai_gen_id }} {
    padding: 24px 0;
    text-align: center;
    color: #999;
    font-size: 14px;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-model-details-content-{{ ai_gen_id }} {
      gap: 16px;
      padding: 20px 0;
    }

    .ai-model-details-image-{{ ai_gen_id }} {
      width: 60px;
      height: 60px;
    }

    .ai-model-details-name-{{ ai_gen_id }} {
      font-size: 14px;
      margin-bottom: 10px;
    }

    .ai-model-details-stats-{{ ai_gen_id }} {
      font-size: 12px;
      gap: 6px 12px;
    }
  }
{% endstyle %}

<div class="ai-model-details-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <hr class="ai-model-details-hr-{{ ai_gen_id }}">
  
  {% if metaobject %}
    <div class="ai-model-details-content-{{ ai_gen_id }}">
      <div class="ai-model-details-image-{{ ai_gen_id }}">
        {% if metaobject.model_image.value %}
          <img
            src="{{ metaobject.model_image.value | image_url: width: 160 }}"
            alt="{{ metaobject.display_name | escape }}"
            width="160"
            height="160"
            loading="lazy"
          >
        {% endif %}
      </div>
      
      <div class="ai-model-details-info-{{ ai_gen_id }}">
        <div class="ai-model-details-name-{{ ai_gen_id }}">
          {{ metaobject.display_name }}
        </div>
        
        <div class="ai-model-details-stats-{{ ai_gen_id }}">
          {% if metaobject.model_height.value %}
            <div class="ai-model-details-stat-{{ ai_gen_id }}">
              <span class="ai-model-details-stat-label-{{ ai_gen_id }}">HEIGHT:</span>
              <span class="ai-model-details-stat-value-{{ ai_gen_id }}">{{ metaobject.model_height.value }}</span>
            </div>
          {% endif %}
          
          {% if metaobject.model_chest.value %}
            <div class="ai-model-details-stat-{{ ai_gen_id }}">
              <span class="ai-model-details-stat-label-{{ ai_gen_id }}">CHEST:</span>
              <span class="ai-model-details-stat-value-{{ ai_gen_id }}">{{ metaobject.model_chest.value }}</span>
            </div>
          {% endif %}
          
          {% if metaobject.model_waist.value %}
            <div class="ai-model-details-stat-{{ ai_gen_id }}">
              <span class="ai-model-details-stat-label-{{ ai_gen_id }}">WAIST:</span>
              <span class="ai-model-details-stat-value-{{ ai_gen_id }}">{{ metaobject.model_waist.value }}</span>
            </div>
          {% endif %}
          
          {% if metaobject.wears.value %}
            <div class="ai-model-details-stat-{{ ai_gen_id }}">
              <span class="ai-model-details-stat-label-{{ ai_gen_id }}">WEARS:</span>
              <span class="ai-model-details-stat-value-{{ ai_gen_id }}">{{ metaobject.wears.value }}</span>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  {% else %}
    <div class="ai-model-details-empty-{{ ai_gen_id }}">
      Next, add model details to this product
    </div>
  {% endif %}
  
  <hr class="ai-model-details-hr-{{ ai_gen_id }}">
</div>

{% schema %}
{
  "name": "Model details",
  "settings": [],
  "presets": [
    {
      "name": "Model details"
    }
  ]
}
{% endschema %}